{
  "name": "@cloudmatrix/identity-service",
  "version": "0.1.0",
  "private": true,
  "description": "Authentication, authorization, and tenant management service",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@cloudmatrix/auth-utils": "workspace:*",
    "@cloudmatrix/logger": "workspace:*",
    "@cloudmatrix/observability": "workspace:*",
    "@cloudmatrix/shared-types": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "pg": "^8.11.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.11.0",
    "rimraf": "^5.0.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
