IDENTITY_SERVICE_PORT=3001
TENANT_ISSUER=https://login.microsoftonline.com/<your-tenant-id>/v2.0
API_AUDIENCE=api://<your-client-id>
ENTRA_CLIENT_ID=<your-client-id>
ENTRA_TENANT_ID=<your-tenant-id>
# Base URL for admin consent redirect callbacks (no trailing slash)
PUBLIC_BASE_URL=https://app.securepulse.ca
APP_INSIGHTS_CONNECTION_STRING=
# Development only: Set to 'true' to bypass authentication (NOT for production)
ALLOW_AUTH_BYPASS=false
