GRAPH_PROXY_PORT=3002
GRAPH_CLIENT_ID=<your-graph-app-registration-client-id>
GRAPH_CLIENT_SECRET=<your-graph-app-registration-client-secret>
# The Entra ID tenant ID of your CloudMatrix service principal (not the customer tenant)
GRAPH_TENANT_ID=<your-cloudmatrix-entra-tenant-id>
GRAPH_SCOPE=https://graph.microsoft.com/.default
APP_INSIGHTS_CONNECTION_STRING=

# Required app registration permissions (application permissions, admin consent required):
#   SecurityEvents.Read.All           - Secure Score and alerts
#   SecurityActions.Read.All          - Secure Score control profiles
#   IdentityRiskyUser.Read.All        - Risky users (Entra ID Protection)
#   DeviceManagementManagedDevices.Read.All - Device compliance
#   SecurityIncident.Read.All         - Defender XDR incidents
