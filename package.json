{
  "name": "cloudmatrix-mssp",
  "private": true,
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:identity": "pnpm --filter identity-service dev",
    "dev:graph-proxy": "pnpm --filter graph-proxy dev",
    "dev:core-backend": "pnpm --filter core-backend dev",
    "dev:automation": "pnpm --filter automation-service dev",
    "dev:ai": "pnpm --filter ai-service dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "migrate:up": "pnpm --filter core-backend migrate:up",
    "migrate:down": "pnpm --filter core-backend migrate:down"
  },
  "devDependencies": {
    "jest": "29.7.0"
  }
}
