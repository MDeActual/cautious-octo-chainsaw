{
  "name": "cloudmatrix-mssp",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Native, Security-First MSSP Platform for Microsoft Cloud Partners",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "migrate:up": "node-pg-migrate --migrations-dir ./migrations up",
    "migrate:down": "node-pg-migrate --migrations-dir ./migrations down",
    "migrate:create": "node-pg-migrate --migrations-dir ./migrations create",
    "migrate:status": "node-pg-migrate --migrations-dir ./migrations status"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "node-pg-migrate": "^7.2.1",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "turbo": "^1.13.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "pg": "^8.11.3"
  }
}
