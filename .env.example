# Identity Service
IDENTITY_SERVICE_PORT=3001
TENANT_ISSUER=https://login.microsoftonline.com/<your-tenant-id>/v2.0
API_AUDIENCE=api://<your-client-id>
ENTRA_CLIENT_ID=<your-client-id>
ENTRA_TENANT_ID=<your-tenant-id>

# Graph Proxy
GRAPH_PROXY_PORT=3002
GRAPH_CLIENT_ID=<your-graph-client-id>
GRAPH_CLIENT_SECRET=<your-graph-client-secret>
GRAPH_SCOPE=https://graph.microsoft.com/.default

# Core Backend
CORE_BACKEND_PORT=3003
GRAPH_PROXY_URL=http://localhost:3002
POSTGRES_URL=postgresql://localhost:5432/cloudmatrix
IDENTITY_SERVICE_URL=http://localhost:3001

# Database (Neon PostgreSQL — used by migration runner and all backend services)
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# Automation Service
AUTOMATION_SERVICE_PORT=3004
AUTOMATION_SERVICE_URL=http://localhost:3004

# AI Service
AI_SERVICE_PORT=3005
AI_SERVICE_URL=http://localhost:3005
AZURE_OPENAI_ENDPOINT=https://<your-openai>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-openai-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4

# Frontend
VITE_ENTRA_CLIENT_ID=<your-client-id>
VITE_ENTRA_TENANT_ID=<your-tenant-id>
VITE_IDENTITY_API=http://localhost:3001
VITE_CORE_API=http://localhost:3003

# Observability
APP_INSIGHTS_CONNECTION_STRING=InstrumentationKey=<your-key>
