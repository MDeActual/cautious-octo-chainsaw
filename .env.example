# =============================================================================
# CloudMatrix MSSP Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to source control.
# =============================================================================

# =============================================================================
# General
# =============================================================================
NODE_ENV=development
LOG_LEVEL=info

# =============================================================================
# Database (PostgreSQL / Neon)
# =============================================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/cloudmatrix_dev

# =============================================================================
# Microsoft Entra ID (Azure AD)
# =============================================================================
ENTRA_TENANT_ID=your-entra-tenant-id
ENTRA_CLIENT_ID=your-entra-client-id
ENTRA_CLIENT_SECRET=your-entra-client-secret

# =============================================================================
# Identity Service (Port 3001)
# =============================================================================
IDENTITY_SERVICE_PORT=3001

# =============================================================================
# Graph Proxy Service (Port 3002)
# =============================================================================
GRAPH_PROXY_PORT=3002
GRAPH_RATE_LIMIT_PER_TENANT=100
GRAPH_RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# Core Backend Service (Port 3003)
# =============================================================================
CORE_BACKEND_PORT=3003
GRAPH_PROXY_URL=http://localhost:3002
AUTOMATION_SERVICE_URL=http://localhost:3004
AI_SERVICE_URL=http://localhost:3005

# =============================================================================
# Automation Service (Port 3004)
# =============================================================================
AUTOMATION_SERVICE_PORT=3004
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/your-webhook-path
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@yourcompany.com
SMTP_PASS=your-smtp-password
SMTP_FROM=CloudMatrix <notifications@yourcompany.com>

# =============================================================================
# AI Service (Port 3005)
# =============================================================================
AI_SERVICE_PORT=3005
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_MAX_TOKENS=2000
AZURE_OPENAI_TEMPERATURE=0.7

# =============================================================================
# Frontend (Port 5173)
# =============================================================================
VITE_ENTRA_CLIENT_ID=your-spa-entra-client-id
VITE_ENTRA_TENANT_ID=your-entra-tenant-id
VITE_ENTRA_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_IDENTITY_API_URL=http://localhost:3001
VITE_CORE_API_URL=http://localhost:3003
VITE_AI_API_URL=http://localhost:3005

# =============================================================================
# Monitoring (Azure Application Insights)
# =============================================================================
APP_INSIGHTS_CONNECTION_STRING=InstrumentationKey=your-instrumentation-key;IngestionEndpoint=https://eastus-0.in.applicationinsights.azure.com/
