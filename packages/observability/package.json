    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@cloudmatrix/logger": "workspace:*",
    "applicationinsights": "^3.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "express": "^4.18.2",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  }
