{
  "name": "@cloudmatrix/observability",
  "version": "0.1.0",
  "private": true,
  "description": "Observability and telemetry for CloudMatrix MSSP services",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
